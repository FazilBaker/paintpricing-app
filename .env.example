# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_MONTHLY_PLAN_ID=
NEXT_PUBLIC_PAYPAL_YEARLY_PLAN_ID=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend
RESEND_API_KEY=

# Activation drip cron (app/api/cron/drip, scheduled daily in vercel.json)
# Set the same value in Vercel Project Settings -> Environment Variables.
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`; the route
# rejects any request without it. Generate with: openssl rand -hex 32
CRON_SECRET=

# Cloudflare Turnstile (signup bot protection)
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# 1. Create a Turnstile site for app.paintpricing.com
# 2. Copy the Site Key into NEXT_PUBLIC_TURNSTILE_SITE_KEY
# 3. Copy the Secret Key into TURNSTILE_SECRET_KEY
# If both are unset, signup form gracefully degrades to gmail-dot regex only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
